# ==================================================
# COLABORAPANC - Configurações de Ambiente
# ==================================================
# Copie este arquivo para .env e ajuste os valores

# --------------------------------------------------
# DJANGO CORE
# --------------------------------------------------
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,foodlens.com.br,www.foodlens.com.br,177.153.58.19

# --------------------------------------------------
# DATABASE (PostgreSQL + PostGIS)
# --------------------------------------------------
POSTGRES_DB=pancdb
POSTGRES_USER=pancuser
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --------------------------------------------------
# E-MAIL
# --------------------------------------------------
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=no-reply@foodlens.com.br
# Para produção com SMTP:
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-password

# --------------------------------------------------
# AUTENTICAÇÃO
# --------------------------------------------------
DJANGO_EMAIL_VERIFICATION=optional
DJANGO_SITE_ID=1

# --------------------------------------------------
# CORS (Segurança)
# --------------------------------------------------
# IMPORTANTE: Em produção, SEMPRE defina como False
# O sistema usará whitelist de domínios específicos
CORS_ALLOW_ALL_ORIGINS=False

# --------------------------------------------------
# API BASE URL (para app mobile)
# --------------------------------------------------
# Para desenvolvimento local
EXPO_PUBLIC_API_URL=http://localhost:8000
# Para produção:
# EXPO_PUBLIC_API_URL=https://foodlens.com.br

# --------------------------------------------------
# APIs EXTERNAS - Identificação de Plantas
# --------------------------------------------------
# Plant.id API - https://web.plant.id/
PLANTID_API_KEY=your-plantid-api-key-here

# PlantNet API - https://my.plantnet.org/
PLANTNET_API_KEY=your-plantnet-api-key-here

# --------------------------------------------------
# APIs EXTERNAS - Geocodificação
# --------------------------------------------------
# LocationIQ API - https://locationiq.com/
LOCATIONIQ_API_KEY=your-locationiq-api-key-here

# --------------------------------------------------
# APIs EXTERNAS - MapBiomas Alerta
# --------------------------------------------------
# MapBiomas Alerta API - https://plataforma.alerta.mapbiomas.org/
# Cadastre-se em: https://plataforma.alerta.mapbiomas.org/signup
MAPBIOMAS_EMAIL=your-email@example.com
MAPBIOMAS_PASSWORD=your-password-here
# ==========================
# Enriquecimento Botânico
# ==========================
ENRICH_HTTP_TIMEOUT=8
ENRICH_HTTP_RETRIES=2
ENRICH_CACHE_TTL_GNV=86400
ENRICH_CACHE_TTL_TROPICOS=86400
ENRICH_CACHE_TTL_GBIF=3600
ENRICH_CACHE_TTL_INAT=3600
ENRICH_CACHE_TTL_TREFLE=43200
ENRICH_CACHE_TTL_WIKIMEDIA=86400

GNAMES_API_URL=https://verifier.globalnames.org/api/v1
TROPICOS_API_URL=https://services.tropicos.org
TROPICOS_API_KEY=your-tropicos-api-key
GBIF_API_URL=https://api.gbif.org/v1
INAT_API_URL=https://api.inaturalist.org/v1
TREFLE_API_URL=https://trefle.io/api/v1
TREFLE_TOKEN=your-trefle-token
TREFLE_API_TOKEN=your-trefle-api-token
PLANTID_API_KEY=your-plantid-api-key
MAPBIOMAS_EMAIL=your-mapbiomas-email
MAPBIOMAS_PASSWORD=your-mapbiomas-password
NASA_FIRMS_MAP_KEY=7fbc21c81aae4bc959d830a9250be833
NASA_FIRMS_SOURCE=VIIRS_SNPP_NRT
NASA_FIRMS_API_URL=https://firms.modaps.eosdis.nasa.gov/api/area/csv
INMET_RSS_URL=https://apiprevmet3.inmet.gov.br/
OPENMETEO_API_URL=https://api.open-meteo.com/v1/forecast

# Wikimedia / Wikipedia (enriquecimento complementar)
COLABORAPANC_VERSION=1.0
WIKIMEDIA_USER=Warleyalisson
WIKIMEDIA_EMAIL=warleyalisson@gmail.com
WIKIMEDIA_USER_AGENT=ColaboraPANC/1.0 (Warleyalisson; warleyalisson@gmail.com)
WIKIMEDIA_API_USER_AGENT=ColaboraPANC/1.0 (Warleyalisson; warleyalisson@gmail.com)
WIKIMEDIA_ENRICHMENT_ENABLED=True
WIKIMEDIA_TIMEOUT_SECONDS=8
WIKIMEDIA_HTTP_RETRIES=2
WIKIMEDIA_MIN_MATCH_CONFIDENCE=0.55
